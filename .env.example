# =============================================================================
# Applairo - variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs.
# `docker compose` lit automatiquement le .env à la racine du projet.
# =============================================================================

# --- Authentification Google (Gemini) ---------------------------------------
# Option A (RECOMMANDÉE - la seule simple en Docker) : clé API Google AI Studio.
# Obtenir sur : https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Option B - Vertex AI. ATTENTION : ne fonctionne PAS tel quel en conteneur.
# `gcloud auth application-default login` écrit les identifiants sur l'hôte
# (~/.config/gcloud), invisibles depuis le conteneur. Pour l'utiliser en Docker,
# montez une clé de compte de service et pointez GOOGLE_APPLICATION_CREDENTIALS
# dessus. En local (hors Docker), l'ADC suffit.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Adzuna (obligatoire) ----------------------------------------------------
# Créer un compte : https://developer.adzuna.com/
# Identifiants    : https://developer.adzuna.com/admin/access_details
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# --- Observabilité (optionnel) -----------------------------------------------
# Niveau de log applicatif : INFO (défaut) ou DEBUG (URLs/paramètres complets).
# LOG_LEVEL=DEBUG
