# =============================================================================
# AUTHENTIFICATION GOOGLE (choisir une option)
# =============================================================================

# Option A — Clé API Google AI Studio (si autorisée par votre organisation)
# Obtenir sur : https://aistudio.google.com/apikey
 GOOGLE_API_KEY=your_google_api_key_here

# Option B — Vertex AI avec ADC (Application Default Credentials)
# Utiliser si les clés API sont bloquées par votre organisation.
# Prérequis : gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1


API_KEY
# =============================================================================
# IDENTIFIANTS ADZUNA
# Créer un compte sur https://developer.adzuna.com/
# Obtenir vos identifiants sur https://developer.adzuna.com/admin/access_details
# =============================================================================
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here
